 # ============================================================
# image-world - Environment Configuration
# ============================================================

# Database (PostgreSQL)
DATABASE_URL=postgresql://imageworld:imageworld_secret@localhost:5432/imageworld

# Storage (MinIO / S3-compatible)
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=auto
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=imageworld-photos
STORAGE_PUBLIC_URL=http://localhost:9000/imageworld-photos

# JWT Secret (change in production!)
JWT_SECRET=change-this-to-a-random-string-in-production

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000
